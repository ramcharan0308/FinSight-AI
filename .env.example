# ==========================================
# FINSIGHT AI ENVIRONMENT CONFIGURATION
# ==========================================

# ------------------------------------------
# BACKEND SETTINGS
# ------------------------------------------
PORT=5000
NODE_ENV=development

# Database Configuration (Prisma)
# Replace credentials if using local postgres, Supabase, or Railway
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/finsight_db?schema=public"

# Authentication Secrets
# Securely generated 256-bit key for signing tokens
JWT_SECRET="super-secret-jwt-signing-key-replace-in-production-environments-32-chars-long"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100 # limit each IP to 100 requests per windowMs

# Groq AI Engine Configuration
# Get your API key from https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# CORS Configuration
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5000"

# ------------------------------------------
# FRONTEND SETTINGS
# ------------------------------------------
# API URL endpoint that Next.js client connects to
NEXT_PUBLIC_API_URL="http://localhost:5000/api/v1"
